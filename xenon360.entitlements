<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- libusb opens vendor-specific USB interfaces (Xbox 360 controllers/guitars). -->
    <key>com.apple.security.device.usb</key>
    <true/>

    <!-- The watcher and the menu bar app quit each other via AppleEvents
         ('tell application id ... to quit'); without this entitlement
         hardened runtime refuses those events. -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- libusb is loaded dynamically from /opt/homebrew/lib (in dev builds)
         or bundled inside the .app (in release builds). Allow either. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
